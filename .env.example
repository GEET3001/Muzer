# Copy this file to .env and fill in the values.
#   cp .env.example .env
# NOTE: use .env (not .env.local) — the Prisma CLI only reads .env.

# PostgreSQL connection string (Docker, Neon, Supabase, RDS, ...)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# NextAuth — REQUIRED. Without a secret the auth/session endpoint hangs and
# the whole app sits on a loading screen.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"   # your public URL in production

# Google OAuth credentials (Google Cloud Console → Credentials)
# Redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# YouTube Data API v3 key — OPTIONAL but strongly recommended in production.
# In-app search and title/thumbnail lookups use the official API when this is
# set (reliable on cloud IPs); without it they scrape YouTube, which data-center
# IPs (Railway, etc.) frequently throttle or block.
# Get one: Google Cloud Console → APIs & Services → enable "YouTube Data API v3"
# → Credentials → Create API key. Restrict it to the YouTube Data API.
YOUTUBE_API_KEY=""

# Razorpay — REQUIRED for the paid queue-bidding feature (hosts link a Route
# account; guests bid to boost a track). Use test-mode keys during development.
# Get them: Razorpay Dashboard → Settings → API Keys. Enable Route on the account.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Secret configured on the Razorpay webhook (Dashboard → Settings → Webhooks).
# The bid webhook verifies every request's HMAC-SHA256 signature against this.
RAZORPAY_WEBHOOK_SECRET=""

# Bidding config. Platform keeps PLATFORM_FEE_PERCENT% of each bid; the rest is
# routed to the host's linked account. Bid amounts are in paise (₹0.01).
PLATFORM_FEE_PERCENT="5"
BID_MIN_PAISE="100"
BID_MAX_PAISE="1000000"
