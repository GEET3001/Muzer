generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id      String   @id @default(uuid())
  email   String   @unique
  provider Provider
  role    Role
  streams Stream[]
  upvotes Upvotes[]
  addedStreams   Stream[]        @relation("StreamAddedBy")
  sessionsHosted Session[]       @relation("SessionHost")
  sessionMembers SessionMember[]
  // Razorpay Route linked account for receiving bid payouts (hosts only). Null
  // until the host onboards; payoutsEnabled flips once KYC/payouts are live.
  razorpayAccountId       String?
  razorpayPayoutsEnabled  Boolean @default(false)
  payments Payment[] @relation("PaymentPayer")
}

model Stream {
  id            String     @id @default(uuid())
  type          StreamType
  url           String
  extractedId   String
  title         String     @default("")
  smallImg      String     @default("")
  bigImg        String     @default("")
  active        Boolean    @default(true)
  upvotes       Upvotes[]
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  sessionId     String?
  session       Session?   @relation(fields: [sessionId], references: [id])
  addedById     String?
  addedBy       User?      @relation("StreamAddedBy", fields: [addedById], references: [id])
  createdAt     DateTime   @default(now())
  // Cumulative paid bid in paise (₹0.01). Only ever incremented by the Razorpay
  // webhook after a captured payment. Queue orders by this first, before votes.
  bidAmountUnits Int       @default(0)
  payments      Payment[]
  @@index([sessionId, bidAmountUnits])
}

model Upvotes {
  id       String  @id @default(uuid())
  userId   String
  streamId String
  // +1 for an upvote, -1 for a downvote. The composite unique below guarantees
  // at most one vote (in either direction) per user per stream.
  value    Int     @default(1)
  user     User    @relation(fields: [userId], references: [id])
  stream   Stream  @relation(fields: [streamId], references: [id])
  @@unique([userId, streamId])
}

enum Role {
  Streamer
  EndUser
}

enum Provider {
  Google
}

enum StreamType {
 Youtube
}

model Session {
  id        String          @id @default(uuid())
  code      String          @unique
  accessCode String
  hostId    String
  host      User            @relation("SessionHost", fields: [hostId], references: [id])
  members   SessionMember[]
  streams   Stream[]
  // The track currently playing. Pinned so votes reorder only the upcoming
  // queue and never swap the song that's already on the deck. Null = deck idle.
  currentStreamId String?
  createdAt DateTime        @default(now())
}

model SessionMember {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  session   Session  @relation(fields: [sessionId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  @@unique([sessionId, userId], name: "sessionId_userId")
}

model Payment {
  id                 String   @id @default(uuid())
  streamId           String
  payerId            String
  amountUnits        Int      // paise
  platformFeeUnits   Int      // paise
  providerRef        String   @unique   // Razorpay order_id
  idempotencyKey     String   @unique
  status             PaymentStatus @default(pending)
  stream             Stream   @relation(fields: [streamId], references: [id])
  payer              User     @relation("PaymentPayer", fields: [payerId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@index([streamId])
  @@index([payerId])
}

enum PaymentStatus {
  pending
  succeeded
  failed
}
